\bool_if:NT \g_@@_is_bachelor_bool
  {
    \cs_set:Npn \thefigure
      {  \thechapter - \int_to_arabic:n { \c@figure } }
    \cs_set:Npn \thetable
      {  \thechapter - \int_to_arabic:n { \c@table  } }
  }
%    \end{macrocode}
% \end{macro}
