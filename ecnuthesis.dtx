\captionsetup
  {
    font          = small,
    labelsep      = quad,
    justification = centering
  }
%    \end{macrocode}
%
% 设置英语标题的名称。
%    \begin{macrocode}
\captionsetup [ figure ] [ bi-second ] { name=Figure }
\captionsetup [ table  ] [ bi-second ] { name=Table  }
%    \end{macrocode}
%
% 
% \begin{macro}{\@makefntext}
% 重定义图表编号。
