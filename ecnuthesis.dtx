  {
    \tl_set:cn { l_@@_info_ #1 _tl      } {#2}
    \tl_set:cn { l_@@_info_ #1 _trim_tl } {#2}
    \tl_replace_all:cnn { l_@@_info_ #1 _trim_tl } { \\ } { ~ }
    \regex_replace_all:nnc
      { \s+ } { \ }
      { l_@@_info_ #1 _trim_tl }
    \regex_replace_all:nnc
      { ([\x{4e00}-\x{9fff}]) \s+ ([\x{4e00}-\x{9fff}]) } { \1 \2 }
      { l_@@_info_ #1 _trim_tl }
  }
%    \end{macrocode}
