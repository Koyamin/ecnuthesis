% 模板默认开启封面页。
%    \begin{macrocode}
    cover         .bool_gset:N = \g_@@_cover_page_bool,
    cover         .default:n = { true },
    cover         .initial:n = { true },
%    \end{macrocode}
% \end{macro}
%
% \begin{macro}{declaration}
