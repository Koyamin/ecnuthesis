\cs_new_protected:Npn \@@_abs_title:n #1
  {
    \group_begin:
      \ctexset 
        { 
          chapter / numbering   = false,
          chapter / format      = \sffamily\bfseries\centering\zihao{-3},
        }
      \chapter* {#1}
    \group_end:
  }
\cs_generate_variant:Nn \@@_abs_title:n { V }
%    \end{macrocode}
% \end{macro}
