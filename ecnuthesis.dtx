\cs_new_protected:Npn \@@_appendix_begin:
  { 
    \cleardoublepage
    \@@_title:V \c_@@_name_appendix_tl
    \setcounter{section}{0}
    \bool_if:NT \g_@@_is_bachelor_bool { \small }
  }
%    \end{macrocode}
