\RenewDocumentEnvironment { appendix } { }
  { \@@_appendix_begin: } { \@@_appendix_end: }
%    \end{macrocode}
% \end{environment}
%
% \begin{macro}{\@@_appendix_begin:}
% 添加附录标题，将附录环境内正文的字号调整为五号。
